# Immich — переменные окружения. Медиа в пул, БД на SSD.
UPLOAD_LOCATION=/mnt/storage/immich
DB_DATA_LOCATION=/opt/docker/immich/postgres
TZ=Europe/Madrid

# Версия Immich (закреплена; поднимайте на новую после проверки changelog).
IMMICH_VERSION=v3.0.1

# Пароль локальной БД (postgres не выставлен наружу). По желанию смените
# на свой (только A-Za-z0-9): openssl rand -hex 16
DB_PASSWORD=postgres

# Ниже менять не нужно
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
