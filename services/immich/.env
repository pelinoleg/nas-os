# Immich — environment variables. Media goes to the pool, DB on the SSD.
UPLOAD_LOCATION=/mnt/storage/immich
DB_DATA_LOCATION=/opt/docker/immich/postgres
TZ=Europe/Madrid

# Immich version (pinned; bump to a new one after checking the changelog).
IMMICH_VERSION=v3.0.1

# Local DB password (postgres is not exposed externally). Change it to your
# own if you like (A-Za-z0-9 only): openssl rand -hex 16
DB_PASSWORD=postgres

# No need to change anything below
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
