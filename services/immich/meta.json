{
  "name": "Immich",
  "desc": "Фото и видео как Google Photos: загрузка с телефона, лица, поиск",
  "category": "media",
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/immich.svg",
  "port": 2283,
  "fields": [
    {"key": "UPLOAD_LOCATION", "label": "Папка медиатеки", "default": "{storage}/immich", "type": "path",
     "hint": "оригиналы фото/видео — в пул"},
    {"key": "DB_DATA_LOCATION", "label": "Папка базы данных", "default": "/opt/docker/immich/postgres", "type": "path",
     "hint": "Postgres на SSD, НЕ в пул mergerfs"},
    {"key": "DB_PASSWORD", "label": "Пароль БД", "default": "{rand}", "secret": true},
    {"key": "DB_USERNAME", "label": "Пользователь БД", "default": "postgres", "adv": true},
    {"key": "DB_DATABASE_NAME", "label": "Имя БД", "default": "immich", "adv": true},
    {"key": "IMMICH_VERSION", "label": "Версия Immich", "default": "v3.0.1", "adv": true},
    {"key": "TZ", "label": "Часовой пояс", "default": "{tz}", "adv": true}
  ],
  "replica": {
    "desc": "Холодная реплика Immich с другого NAS: дамп Postgres по SSH + rsync медиатеки; реплика поднимается той же версией, что источник",
    "version_cmd": "docker inspect --format {{.Config.Image}} immich_server",
    "dump_cmd": "docker exec immich_postgres sh -c 'pg_dumpall --clean --if-exists --username=$POSTGRES_USER' | gzip",
    "db_container": "immich_postgres",
    "db_service": "database",
    "psql_cmd": "sh -c 'psql --username=$POSTGRES_USER --dbname=postgres'",
    "version_env": "IMMICH_VERSION",
    "data_env": "UPLOAD_LOCATION",
    "wait_db_cmd": "sh -c 'until pg_isready --username=$POSTGRES_USER >/dev/null 2>&1; do sleep 2; done'"
  }
}
