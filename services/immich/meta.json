{
  "name": "Immich",
  "desc": "Photos and videos like Google Photos: phone upload, faces, search",
  "category": "media",
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/immich.svg",
  "port": 2283,
  "fields": [
    {"key": "UPLOAD_LOCATION", "label": "Media library folder", "default": "{storage}/immich", "type": "path",
     "hint": "photo/video originals — to the pool"},
    {"key": "DB_DATA_LOCATION", "label": "Database folder", "default": "/opt/docker/immich/postgres", "type": "path",
     "hint": "Postgres on the SSD, NOT in the mergerfs pool"},
    {"key": "DB_PASSWORD", "label": "DB password", "default": "{rand}", "secret": true},
    {"key": "DB_USERNAME", "label": "DB user", "default": "postgres", "adv": true},
    {"key": "DB_DATABASE_NAME", "label": "DB name", "default": "immich", "adv": true},
    {"key": "IMMICH_VERSION", "label": "Immich version", "default": "v3.0.1", "adv": true},
    {"key": "TZ", "label": "Time zone", "default": "{tz}", "adv": true}
  ],
  "replica": {
    "desc": "A cold Immich replica from another NAS: Postgres dump over SSH + rsync of the media library; the replica runs the same version as the source",
    "version_cmd": "docker inspect --format {{.Config.Image}} immich_server",
    "dump_cmd": "docker exec immich_postgres sh -c 'pg_dumpall --clean --if-exists --username=$POSTGRES_USER' | gzip",
    "db_container": "immich_postgres",
    "db_service": "database",
    "psql_cmd": "sh -c 'psql --username=$POSTGRES_USER --dbname=postgres'",
    "version_env": "IMMICH_VERSION",
    "data_env": "UPLOAD_LOCATION",
    "wait_db_cmd": "sh -c 'until pg_isready --username=$POSTGRES_USER >/dev/null 2>&1; do sleep 2; done'"
  }
}
