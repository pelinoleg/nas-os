# TEMPLATE. Copy the folder, rename the file to docker-compose.yml, edit it.
# The wizard only sees docker-compose.yml / .yaml / compose.yml / .yaml (NOT .example).
services:
  myservice:
    image: ghcr.io/example/myservice:1.2.3    # pinned tag, NOT latest
    container_name: myservice
    restart: unless-stopped
    environment:
      - TZ=Europe/Madrid
      # - PUID=1000
      # - PGID=1000
    ports:
      - "8080:8080"
    volumes:
      - /opt/docker/myservice/config:/config          # container config
      - /mnt/storage/myservice:/data                   # data on the mergerfs pool
    security_opt:
      - no-new-privileges:true
