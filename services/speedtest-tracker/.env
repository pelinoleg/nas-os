# Speedtest Tracker — переменные окружения.
# Этот файл НЕ коммитьте с реальным ключом.
#
# APP_KEY обязателен. Сгенерировать:
#   echo "base64:$(openssl rand -base64 32)"
APP_KEY=

# Адрес, по которому открываете панель (нужен Laravel для ссылок и cookie).
APP_URL=http://pi5.local:8440

PUID=1000
PGID=1000
TZ=Europe/Madrid

# Как часто мерить скорость (cron). Каждый час:
SPEEDTEST_SCHEDULE=0 * * * *
