# The NAS-OS repo lives in the home folder next to personal files and ~/nas-config.
# Ignore EVERYTHING at the top level, then explicitly allow only project files,
# so that `git add -A` doesn't drag in home-folder clutter, config, and caches.
/*
!/.gitignore
!/README.md
!/CLAUDE.md
!/DESIGN.md
!/install.sh
!/nas-web.py
!/nas-wizard.sh
!/nas-web.service
!/nas-web-install.sh
!/check.sh
!/dialogrc-nas
!/web/
!/services/
!/.claude/
.claude/settings.local.json

# inside web/: don't carry the wallpaper/preview cache (that's runtime), the rest (icons, assets) — in the repo
web/wallpaper.*
web/.nas-trash/

# python/OS junk
__pycache__/
*.pyc
.DS_Store

# per-stack env is generated from meta.json fields at install (never commit secrets)
services/*/.env
