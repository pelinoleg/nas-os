# NAS-OS репозиторий живёт в домашней папке рядом с личными файлами и ~/nas-config.
# Игнорируем ВСЁ на верхнем уровне, затем явно разрешаем только файлы проекта,
# чтобы `git add -A` не затянул домашний мусор, конфиг и кэши.
/*
!/.gitignore
!/README.md
!/CLAUDE.md
!/DESIGN.md
!/install.sh
!/nas-web.py
!/nas-wizard.sh
!/nas-web.service
!/nas-web-install.sh
!/check.sh
!/dialogrc-nas
!/web/
!/services/
!/.claude/
.claude/settings.local.json

# внутри web/: не тащим кэш обоев и превью (это runtime), остальное (иконки, ассеты) — в репо
web/wallpaper.*
web/.nas-trash/

# python/OS мусор
__pycache__/
*.pyc
.DS_Store
